rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    function isAdmin() {
      return request.auth != null
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'user') == 'admin';
    }

    function isNonNegativeInt(field) {
      return field is int && field >= 0;
    }

    function isIsoString(field) {
      return field is string && field.size() >= 10;
    }

    // Fields a user may write on CREATE (role is intentionally excluded)
    function hasOnlyProfileCreateKeys() {
      return request.resource.data.keys().hasOnly([
        'name',
        'gender',
        'birthMonth',
        'birthYear',
        'height',
        'weight',
        'targetWeight',
        'activityLevel',
        'goal',
        'joinedDate',
        'photoUrl'
      ]);
    }

    // Fields a user may write on UPDATE (role is intentionally excluded)
    // Uses affectedKeys() to check only fields being changed, not the whole merged document
    function hasOnlyAllowedUpdateKeys() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
        'name',
        'gender',
        'birthMonth',
        'birthYear',
        'height',
        'weight',
        'targetWeight',
        'activityLevel',
        'goal',
        'joinedDate',
        'photoUrl'
      ]);
    }

    // Ensures the role field is never changed by the client
    function roleUnchanged() {
      return !('role' in request.resource.data)
        || ('role' in resource.data && request.resource.data.role == resource.data.role);
    }

    function joinedDateUnchanged() {
      return !('joinedDate' in resource.data)
        || request.resource.data.joinedDate == resource.data.joinedDate;
    }

    function profileBaseValid() {
      return request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 80
        && request.resource.data.gender in ['male', 'female']
        && request.resource.data.birthMonth is int
        && request.resource.data.birthMonth >= 1
        && request.resource.data.birthMonth <= 12
        && request.resource.data.birthYear is int
        && request.resource.data.birthYear >= 1900
        && request.resource.data.birthYear <= 2100
        && request.resource.data.height is number
        && request.resource.data.height >= 100
        && request.resource.data.height <= 260
        && request.resource.data.weight is number
        && request.resource.data.weight >= 20
        && request.resource.data.weight <= 400
        && (!('targetWeight' in request.resource.data)
          || request.resource.data.targetWeight == null
          || (request.resource.data.targetWeight is number
            && request.resource.data.targetWeight >= 20
            && request.resource.data.targetWeight <= 400))
        && request.resource.data.activityLevel in ['sedentary', 'light', 'moderate', 'active']
        && request.resource.data.goal in ['lose', 'maintain', 'gain']
        && isIsoString(request.resource.data.joinedDate)
        && (!('photoUrl' in request.resource.data)
          || request.resource.data.photoUrl == null
          || (request.resource.data.photoUrl is string
            && !request.resource.data.photoUrl.matches('^data:')));
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && hasOnlyProfileCreateKeys() && profileBaseValid();
      allow update: if isOwner(userId)
        && hasOnlyAllowedUpdateKeys()
        && profileBaseValid()
        && roleUnchanged()
        && joinedDateUnchanged();

      match /daily_logs/{logId} {
        allow read, write: if isOwner(userId);
      }

      match /workout_sessions/{sessionId} {
        allow read, write: if isOwner(userId);
      }
    }

    match /feedback/{feedbackId} {
      // ผู้ใช้ที่ล็อกอินแล้วส่ง Feedback ได้
      allow create: if request.auth != null
        && request.resource.data.keys().hasOnly([
          'uid', 'rating', 'comment', 'favoriteFeature', 'createdAt'
        ])
        && request.resource.data.rating is int
        && request.resource.data.rating >= 1
        && request.resource.data.rating <= 5
        && request.resource.data.uid == request.auth.uid;

      // อ่านได้เฉพาะ Admin
      allow read: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
